{
    "configurations": [
        {
            "name": "AVR",
            "compilerPath": "/usr/bin/avr-gcc",
            "intelliSenseMode": "gcc-x64",
            "cStandard": "c11",
            "cppStandard": "c++17",

            "includePath": [
                "${workspaceFolder}/**",
                "/usr/lib/avr/include",
                "/usr/lib/gcc/avr/**"
            ],

            "compilerArgs": [
                "-mmcu=atmega328p",
                "-Os",
                "-Wall",
                "-Wextra"
            ]
        }
    ],
    "version": 4
}